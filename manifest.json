{
  "manifest_version": 3,
  "name": "Open on Map for Google Search",
  "description": "Adds an Open on map button to Google Search when a location is shown.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.google.com/search*",
        "*://www.google.pl/search*",
        "*://www.google.com.ua/search*",
        "*://www.google.de/search*",
        "*://www.google.fr/search*",
        "*://www.google.co.uk/search*",
        "*://www.google.it/search*",
        "*://www.google.es/search*",
        "*://www.google.com.br/search*",
        "*://www.google.ca/search*",
        "*://www.google.com.au/search*",
        "*://www.google.co.jp/search*",
        "*://www.google.ru/search*",
        "*://www.google.nl/search*",
        "*://www.google.cz/search*",
        "*://www.google.sk/search*",
        "*://www.google.hu/search*",
        "*://www.google.at/search*",
        "*://www.google.be/search*",
        "*://www.google.ch/search*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "open-on-map-google-search@example.com",
      "strict_min_version": "109.0"
    }
  }
}
